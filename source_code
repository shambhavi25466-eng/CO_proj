# Function for Translation
def translate_to_binary(line, lineno):
    line = line.strip().replace(', ', ',')
    if not line:
        return ''
    if ":" in line:
        colon_pos = line.index(":")
        ln  = line[0:colon_pos]    # ln = label name
        line = line[colon_pos + 1:].strip()
    if not line:
        return ''

    parts = line.split()  # "add s1,s2,s3" becomes ["add", "s1,s2,s3"]

    mnemonic = parts[0].strip()  # parts[0] is the mnemonic

    args = []
    if len(parts) > 1:
        arg_str = parts[1].strip()
        arg_str = arg_str.replace("(", ",").replace(")", "")  # lw a5,20(s1) -> "20,s1"
        for a in arg_str.split(","):
            args.append(a.strip())  # "a5,20,s1" becomes ["a5", "20", "s1"]

    pc = lineno * 4

