    elif mnemonic in i2 and len(i2[mnemonic]) == 2:   # for S type
        funct3 = i2[mnemonic][0]
        opcode = i2[mnemonic][1]
        rs1 = Register_file[args[2]]
        rs2 = Register_file[args[0]]
        imm = twosComplement(args[1], 12)
