                la = labels[ln]  
            offset = la - pc
            imm = twosComplement(offset, 21)
            return imm[0] + imm[10:20] + imm[9] + imm[1:9] + rd + opcode
        else:   # for U type
            imm = twosComplement(args[1], 20)
            return imm + rd + opcode
