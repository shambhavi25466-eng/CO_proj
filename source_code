        funct7 = i3[mnemonic][0]
        funct3 = i3[mnemonic][1]
        opcode = i3[mnemonic][2]
        rd  = Register_file[args[0]]
        rs1 = Register_file[args[1]]
        rs2 = Register_file[args[2]]
        return funct7 + rs2 + rs1 + funct3 + rd + opcode

    elif mnemonic in i3 and len(i3[mnemonic]) == 2:
        funct3 = i3[mnemonic][0]
